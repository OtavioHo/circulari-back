# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL="postgresql://circulari:circulari@localhost:5432/circulari_dev?schema=public"

# Storage (MinIO)
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=circulari
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=us-east-1
# STORAGE_PUBLIC_URL=http://localhost:9000/circulari

# Email
EMAIL_PROVIDER=stalwart   # stalwart | resend | mock
EMAIL_FROM=no-reply@example.com
STALWART_SMTP_HOST=
STALWART_SMTP_PORT=587
STALWART_SMTP_USER=
STALWART_SMTP_PASS=
RESEND_API_KEY=

# AI (image analysis)
OPENAI_API_KEY=
# OPENAI_VISION_MODEL=gpt-4o   # default: gpt-4o (must support vision)

# RevenueCat (monetization) — SERVER-SIDE SECRETS ONLY (never ship in the app)
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_API_KEY=
# REVENUECAT_API_URL=https://api.revenuecat.com/v1
# Entitlement identifiers that map to each paid tier (must match RevenueCat dashboard)
# REVENUECAT_ENTITLEMENT_ESSENCIAL=essencial
# REVENUECAT_ENTITLEMENT_PRO=pro

# Tier limits (optional overrides). AI is unlimited on paid tiers (not configurable).
# Free
# FREE_MAX_LISTS=1
# FREE_MAX_ITEMS=50
# FREE_MAX_AI_CALLS_PER_MONTH=10
# Essencial (R$ 19,90/mo)
# ESSENCIAL_MAX_LISTS=3
# ESSENCIAL_MAX_ITEMS=70
# Pro (R$ 49,90/mo)
# PRO_MAX_LISTS=5
# PRO_MAX_ITEMS=150
