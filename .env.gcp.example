# GCP Cloud Run environment — reference only.
# These values are injected via Secret Manager and --set-env-vars in deploy.sh.
# Do NOT use this file directly in production.

NODE_ENV=production
PORT=3000

# Cloud SQL via Unix socket (injected as secret DATABASE_URL)
DATABASE_URL=postgresql://circulari:PASSWORD@localhost/circulari?host=/cloudsql/PROJECT:southamerica-east1:circulari-db

# GCS (S3-compatible) — non-secret values set directly in deploy.sh
STORAGE_PROVIDER=s3
STORAGE_ENDPOINT=https://storage.googleapis.com
STORAGE_REGION=auto
STORAGE_BUCKET=PROJECT-circulari-storage
STORAGE_PUBLIC_URL=https://storage.googleapis.com/PROJECT-circulari-storage

# GCS HMAC keys (injected as secrets)
STORAGE_ACCESS_KEY=HMAC_ACCESS_KEY
STORAGE_SECRET_KEY=HMAC_SECRET_KEY

# AI (injected as secrets)
# Primary: Gemini grounded pricing (billing-enabled project required).
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3-flash-preview
# Fallback: OpenAI vision (ungrounded).
OPENAI_API_KEY=

# RevenueCat (injected as secrets)
REVENUECAT_WEBHOOK_SECRET=
REVENUECAT_API_KEY=
# Entitlement ids that map to each paid tier (must match the RevenueCat dashboard)
REVENUECAT_ENTITLEMENT_ESSENCIAL=essencial
REVENUECAT_ENTITLEMENT_PRO=pro

# Email (injected as secrets)
EMAIL_PROVIDER=smtp
EMAIL_FROM=
STALWART_SMTP_HOST=
STALWART_SMTP_PORT=587
STALWART_SMTP_USER=
STALWART_SMTP_PASS=
