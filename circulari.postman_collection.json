            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Lamp\",\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/items/:id",
              "host": ["{{baseUrl}}"],
              "path": ["items", ":id"],
              "variable": [
                { "key": "id", "value": "<item-id>" }
              ]
            }
          }
        },
        {
          "name": "DELETE /items/:id",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/items/:id",
              "host": ["{{baseUrl}}"],
              "path": ["items", ":id"],
              "variable": [
                { "key": "id", "value": "<item-id>" }
              ]
            }
          }
        }
      ]
    },
